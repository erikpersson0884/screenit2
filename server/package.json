{
    "name": "screenit-backend",
    "version": "1.0.0",
    "description": "The backend for screenit application.",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "nodemon --watch \"src/**/*.ts\" --exec \"node --loader ts-node/esm\" src/server.ts",
        "test": "vitest",
        "test:watch": "vitest --watch"
    },
    "keywords": [
        "API",
        "Express",
        "TypeScript",
        "JWT",
        "Authentication",
        "Authorization"
    ],
    "author": "Erik Persson",
    "dependencies": {
        "@prisma/adapter-pg": "7.4.0",
        "@prisma/client": "^7.6.0",
        "dotenv": "^17.2.2",
        "express": "^5.1.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "prisma": "^7.6.0",
        "ts-node": "^10.9.2",
        "vitest": "^3.2.4",
        "zod": "^4.1.11"
    },
    "devDependencies": {
        "@types/dotenv": "^6.1.1",
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.5.2",
        "nodemon": "^3.1.10",
        "typescript": "^5.9.2"
    }
}
