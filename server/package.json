{
    "name": "screenit-backend",
    "version": "1.0.0",
    "description": "The backend for screenit application.",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
        "test": "vitest",
        "test:watch": "vitest --watch"
    },
    "keywords": [
        "API",
        "Express",
        "TypeScript",
        "JWT",
        "Authentication",
        "Authorization"
    ],
    "author": "Erik Persson",
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@prisma/adapter-pg": "7.4.0",
        "@prisma/client": "^7.6.0",
        "dotenv": "^17.2.2",
        "express": "^5.1.0",
        "gammait": "^1.0.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "prisma": "^7.6.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "vitest": "^3.2.4",
        "winston": "^3.19.0",
        "zod": "^4.1.11"
    },
    "devDependencies": {
        "@types/dotenv": "^6.1.1",
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.12.2",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "nodemon": "^3.1.10",
        "tsx": "^4.21.0",
        "typescript": "^5.9.2"
    }
}
