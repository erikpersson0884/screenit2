// schema.prisma

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}
  
generator client {
    provider = "prisma-client-js"
}

enum Role {
    admin
    user
}


model User {
    id        String      @id @default(uuid()) // Use Auto Increment for ID
    username  String      @unique
    password  String
    role      Role        @default(user)
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
}
